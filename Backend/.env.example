# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/hostelmate

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Server Port
PORT=5000

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v19.0

# Cloudinary (Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# URLs (CORS & Redirection)
FRONTEND_URL=https://hostelmate.app
PUBLIC_URL=https://hostelmate.app/hostel
LOGIN_URL=https://hostelmate.app/login
